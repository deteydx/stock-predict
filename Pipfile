[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
stockpredict = {editable = true, path = "."}

[dev-packages]
pytest = ">=8"
pytest-asyncio = ">=0.24"
httpx = ">=0.27"
ruff = "*"
mypy = "*"

[requires]
python_version = "3.13"

[scripts]
dev = "python scripts/run_project.py"
analyze = "stockpredict analyze"
serve = "stockpredict serve"
test = "pytest"
lint = "ruff check ."
typecheck = "mypy src"

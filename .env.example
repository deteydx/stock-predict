# IBKR Gateway / TWS
IBKR_HOST=127.0.0.1
IBKR_PORT=7497            # 7497 paper TWS | 7496 live TWS | 4002 paper GW | 4001 live GW
IBKR_CLIENT_ID=17
IBKR_READONLY=true

# Data sources
FRED_API_KEY=
FINNHUB_API_KEY=

# AI
AI_ENABLED=true
AI_PROVIDER=openai          # "openai" | "claude"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ML
ML_ENABLED=false
ML_RULE_WEIGHT=0.7
ML_WEIGHT=0.3

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/stockpredict.db
CACHE_DIR=./cache
REPORTS_DIR=./reports

# Auth
AUTH_SESSION_DAYS=30
AUTH_COOKIE_NAME=stockpredict_session
AUTH_COOKIE_SECURE=false
